pipeline {
    agent any
    
    stages {
        stage('Checkout') {
            steps {
                git branch: 'main', 
                credentialsId: 'jnekins_ci', 
                url: 'https://github.com/pabhishek1994-pixel/simple-java-maven-app.git'
            
            }
        }
        // stage('Build') {
        //     steps {
        //         sh 'mvn -B -DskipTests clean package'
        //     }
        // }
        
        stage('Sonar') {
            steps {
                withCrendentials([string(credentialsId: 'sonar-server', variable: 'SONAR_TOKEN')])
                    sh """
                        sonar scanner -Dsonar.host.url=${SONAR_HOST_URL} -Dsonar.login=${SONAR_TOKEN}
                    """
            }
        }
        
    }
}
